# Copy this file to .env and fill in the two required values below.
# Everything else is optional — the defaults work fine for most cases.

# =============================================================================
# 1. DATABASE  (required)
# =============================================================================
#   SQLite:      sqlite:///path/to/file.db
#   PostgreSQL:  postgresql://user:password@localhost:5432/mydb
#   MySQL:       mysql+pymysql://user:password@localhost:3306/mydb
#   MSSQL:       mssql+pyodbc://user:pass@server/dbname?driver=ODBC+Driver+17+for+SQL+Server
#   Oracle:      oracle+cx_oracle://user:pass@host:1521/service
DB_URL=sqlite:///sample.db

# =============================================================================
# 2. LLM  (optional — remove or set to "none" to skip AI descriptions)
# =============================================================================
# Provider: openai | anthropic | ollama | openrouter | openai_compatible | none
LLM_PROVIDER=none
LLM_MODEL=

# API key for your chosen provider (only set the one you need):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...       # openrouter.ai — 200+ models, free tier available

# Ollama runs locally — no key needed:
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible (LM Studio, vLLM, Together AI, etc.):
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1
# OPENAI_COMPATIBLE_API_KEY=not-needed

# =============================================================================
# Optional settings  (safe to ignore — defaults shown)
# =============================================================================
# OUTPUT_DIR=./output
# TABLE_FILTER=              # comma-separated names or regex, e.g. "dim_.*,fact_.*"
# DB_SCHEMA=                 # limit to one schema, e.g. "public"
# EXPORT=html                # html | json | csv | all
# MAX_SAMPLE_ROWS=100000     # rows sampled per table for profiling (0 = all)
# SAMPLE_DATA_ROWS=5         # sample rows shown in the data dictionary
# LLM_CALL_DELAY=1.0         # seconds between LLM calls — increase for free-tier models
